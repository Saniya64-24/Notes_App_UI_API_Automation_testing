pipeline {
    agent any
    stages {
        stage('Clone Repository') {
            steps {
                git branch: 'master',
                    url: 'https://github.com/Saniya64-24/Notes_App_UI_API_Automation_testing.git'
            }
        }
        stage('Check Python Version') {
            steps {
                bat '"C:\\Program Files\\Python310\\python.exe" --version'
            }
        }
        stage('Install Dependencies') {
            steps {
                bat 'cd c_Selenium_Python_Advanced_Capstone_Project && "C:\\Program Files\\Python310\\Scripts\\pip.exe" install -r requirements.txt'
            }
        }
        stage('Run Automation Tests') {
            steps {
                bat 'cd c_Selenium_Python_Advanced_Capstone_Project && "C:\\Program Files\\Python310\\Scripts\\pytest.exe" -v --alluredir=allure-results'
            }
        }
        stage('Generate Allure Report') {
            steps {
                bat 'cd c_Selenium_Python_Advanced_Capstone_Project && "C:\\Users\\khade\\scoop\\shims\\allure.cmd" generate allure-results --clean -o allure-report'
            }
        }
        stage('Archive Allure Report') {
            steps {
                archiveArtifacts artifacts: 'c_Selenium_Python_Advanced_Capstone_Project/allure-report/**', fingerprint: true
            }
        }
    }
}